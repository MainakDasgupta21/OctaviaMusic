# =============================================================================
# Frontend (Vite) — read by `src/lib/api.js`.
# =============================================================================

# Backend API base URL.
# In development this points at the bundled Express server in /server.
# In production, point this at your deployed server.
VITE_API_BASE=http://localhost:5000/api


# =============================================================================
# Backend (server/) — read by `server/lib/ytmusic.js`.
# All keys below are OPTIONAL; sensible defaults are used when unset.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth + database
# -----------------------------------------------------------------------------
# MongoDB Atlas connection string. Required in production.
MONGODB_URI=

# CORS allowlist (comma-separated). Include the frontend origin when using
# cookie auth; credentials are enabled server-side.
CORS_ORIGIN=http://localhost:8080

# JWT signing secrets (32+ random bytes each). Required in production.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token expiry windows
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Password hashing cost (bcrypt rounds; minimum enforced at 12)
BCRYPT_ROUNDS=12

# Cookie settings
COOKIE_DOMAIN=
COOKIE_SECURE=true

# Auth rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# Optional admin bootstrap for `npm run seed:admin` in server/
# ADMIN_BOOTSTRAP_EMAIL=
# ADMIN_BOOTSTRAP_PASSWORD=

# Optional YouTube playlist IDs (regular `PL...` ids work) to drive the
# /api/charts and /api/trending endpoints. Each is read in a single fast call.
# When unset, the server uses sensible built-in default hit playlists, and
# falls back to a broad video search only if those fail.
# YTM_CHARTS_PLAYLIST=
# YTM_TRENDING_PLAYLIST=

# In-memory cache TTLs (minutes). The server coalesces concurrent identical
# requests automatically; these knobs control how long the result is reused.
# YTM_CACHE_SEARCH_MIN=5
# YTM_CACHE_DETAIL_MIN=30
# YTM_CACHE_CHARTS_MIN=60
# YTM_CACHE_GENRES_MIN=60

# =============================================================================
# Real charts integration (server/lib/charts-service.js)
#
# Data sources used by /api/charts and /api/charts/artists:
#   • Last.fm   — rankings, play counts, listener counts, geo charts, tags.
#                 Required. Create one at:
#                 https://www.last.fm/api/account/create
#   • MusicBrainz — artist nationality, recording release date.
#                 No key required.
#   • YouTube Music — playable videoId, album cover thumbnail, durations,
#                 artist photos. Sourced via the in-process `ytmusic-api`
#                 client (no key required).
#
# Spotify is intentionally NOT used. As of 2025 their Web API requires an
# active Spotify Premium subscription on the developer's own account, which
# makes the source unavailable for free-tier developers. Last.fm + YTM cover
# every field the page renders.
# =============================================================================

# Last.fm API key — required for /api/charts and /api/charts/artists.
LASTFM_API_KEY=

# =============================================================================
# Explore expansion flags (frontend)
# =============================================================================
# VITE_EXPLORE_V2_ENABLED=true
# VITE_EXPLORE_LOOPS_ENABLED=true
# VITE_EXPLORE_SOCIAL_ENABLED=true
# VITE_EXPLORE_INFINITE_ENABLED=true

# =============================================================================
# Explore backend caching knobs (server/lib/explore-service.js)
# =============================================================================
# EXPLORE_CACHE_MAX_ENTRIES=300
# EXPLORE_PULSE_TTL_MS=120000
# EXPLORE_RADIO_TTL_MS=90000
# EXPLORE_SIMILAR_TTL_MS=300000
# EXPLORE_JOURNEY_TTL_MS=180000
