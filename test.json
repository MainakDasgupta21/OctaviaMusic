{
  "project_title": "RhythmStream - Premium MERN Stack Music Player with Video Ambience",
  "role": "Senior Full-Stack Developer and UI/UX Designer with deep expertise in MERN stack (MongoDB, Express.js, React.js, Node.js), Tailwind CSS, and Framer Motion. All code must be in JavaScript. TypeScript must NOT be used anywhere in the project.",
  "goal": {
    "primary_objective": "Design and build a visually stunning, high-performance, futuristic music streaming web application with a premium feel.",
    "core_experience": "Users should feel immersed in a cinematic music environment where audio playback, motion design, and ambient visuals blend seamlessly.",
    "key_highlight": "Play music sourced from YouTube Music while looping silent, aesthetic background videos to create a luxury, screensaver-like ambience.",
    "design_expectation": "The UI must look production-ready, comparable to top-tier consumer apps like Apple Music or Spotify Canvas, but with a more experimental and futuristic edge."
  },
  "technology_stack": {
    "frontend": {
      "framework": {
        "name": "React.js",
        "build_tool": "Vite",
        "language": "JavaScript (ES6+ only)"
      },
      "styling": {
        "framework": "Tailwind CSS",
        "design_principles": [
          "utility-first styling",
          "responsive-first design",
          "dark-mode-first UI",
          "glassmorphism effects using backdrop filters"
        ]
      },
      "animations": {
        "library": "Framer Motion",
        "usage": [
          "vinyl disc rotation animation",
          "hover and tap micro-interactions",
          "page transitions using AnimatePresence",
          "smooth deceleration and acceleration physics"
        ]
      },
      "state_management": {
        "primary": "React Context API",
        "alternative": "Redux Toolkit",
        "state_scope": [
          "authentication state",
          "current playing song",
          "playback status (play, pause, shuffle, loop)",
          "queue management",
          "user preferences and settings"
        ]
      },
      "icons": {
        "libraries": [
          "Lucide-React",
          "Heroicons"
        ],
        "usage_guidelines": "Icons must be minimal, thin-stroke, and consistent with the futuristic UI theme."
      },
      "fonts": {
        "primary": "Plus Jakarta Sans",
        "secondary": "Inter",
        "usage": {
          "headings": "bold, large, high-contrast",
          "body": "medium weight, high readability",
          "metadata": "small, muted, secondary tone"
        }
      }
    },
    "backend": {
      "runtime": "Node.js",
      "framework": "Express.js",
      "architecture": {
        "pattern": "RESTful API",
        "folder_structure": [
          "routes",
          "controllers",
          "models",
          "middlewares",
          "utils"
        ]
      },
      "responsibilities": [
        "handle YouTube Music search requests",
        "manage user authentication and sessions",
        "store playlists and favorites",
        "proxy and sanitize external API calls"
      ]
    },
    "database": {
      "db": "MongoDB",
      "odm": "Mongoose",
      "design_principles": [
        "normalized schemas",
        "indexed frequently queried fields",
        "scalable for millions of users"
      ]
    },
    "audio_source": {
      "type": "YouTube Music",
      "integration_methods": [
        "ytmusic-api wrapper",
        "custom scraping logic when required"
      ],
      "constraints": [
        "audio-only playback",
        "no visible YouTube UI",
        "custom player controls only"
      ]
    }
  },
